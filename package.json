{
  "name": "template-vue-h5",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:test": "vue-tsc -b && vite build --mode test",
    "build:pre": "vue-tsc -b && vite build --mode pre",
    "build:prod": "vue-tsc -b && vite build --mode prod",
    "preview": "pnpm build:test && vite preview",
    "report": "vue-tsc -b && vite build --mode prod",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "type-check": "vue-tsc -b --noEmit",
    "create:component": "esno scripts/create-component.ts",
    "create:page": "esno scripts/create-page.ts",
    "create:store": "esno scripts/create-store.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@types/lodash-es": "^4.17.12",
    "js-cookie": "^3.0.8",
    "lodash-es": "^4.18.1",
    "pinia": "^4.0.2",
    "tailwind-merge": "^3.6.0",
    "vant": "^4.10.0",
    "vconsole": "^3.15.1",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "xy-enum": "^2.1.2",
    "xy-http": "^2.0.1",
    "xy-storage": "^4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@iconify-json/tdesign": "^1.2.17",
    "@iconify/tailwind": "^1.2.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.1",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.4",
    "consola": "^3.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-format": "^2.0.1",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.20",
    "postcss-pxtorem": "^6.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.19",
    "typescript": "6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.5",
    "vue-tsc": "^3.3.7"
  },
  "lint-staged": {
    "*.{ts,vue,js,json,scss}": [
      "pnpm lint"
    ]
  }
}
